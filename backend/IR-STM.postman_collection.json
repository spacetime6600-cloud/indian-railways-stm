            ],
            "url": { "raw": "{{baseUrl}}/api/maintenance", "host": ["{{baseUrl}}"], "path": ["api","maintenance"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assetType\": \"locomotive\",\n  \"assetId\": \"12301\",\n  \"condition\": \"fair\",\n  \"riskLevel\": \"medium\",\n  \"nextServiceDate\": \"2026-05-01T00:00:00.000Z\",\n  \"notes\": \"Scheduled wheel inspection\",\n  \"status\": \"scheduled\"\n}"
            }
          }
