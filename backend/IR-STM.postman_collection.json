            ],
            "url": { "raw": "{{baseUrl}}/api/platforms", "host": ["{{baseUrl}}"], "path": ["api","platforms"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platformNumber\": \"PF-1\",\n  \"stationName\": \"New Delhi (NDLS)\",\n  \"occupied\": false,\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Update Platform",
          "request": {
            "method": "PUT",
