            ],
            "url": { "raw": "{{baseUrl}}/api/alerts", "host": ["{{baseUrl}}"], "path": ["api","alerts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"delay\",\n  \"severity\": \"critical\",\n  \"title\": \"Severe Delay — 12301\",\n  \"message\": \"Howrah Rajdhani delayed by 45 minutes due to signal failure.\",\n  \"stationName\": \"New Delhi (NDLS)\"\n}"
            }
          }
        },
        {
          "name": "Resolve Alert",
          "request": {
            "method": "PUT",
