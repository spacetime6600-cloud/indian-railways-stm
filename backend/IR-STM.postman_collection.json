            ],
            "url": { "raw": "{{baseUrl}}/api/maintenance/:id", "host": ["{{baseUrl}}"], "path": ["api","maintenance",":id"], "variable": [{ "key": "id", "value": "" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"condition\": \"good\",\n  \"riskLevel\": \"low\",\n  \"status\": \"completed\",\n  \"notes\": \"Inspection passed\"\n}"
            }
          }
        },
        {
          "name": "Delete Maintenance Record",
          "request": {
            "method": "DELETE",
