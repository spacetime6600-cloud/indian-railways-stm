            "url": { "raw": "{{baseUrl}}/api/alerts/:id/resolve", "host": ["{{baseUrl}}"], "path": ["api","alerts",":id","resolve"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Delete Alert",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/alerts/:id", "host": ["{{baseUrl}}"], "path": ["api","alerts",":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },
    {
      "name": "Maintenance",
      "item": [
        {
          "name": "Get All Maintenance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/maintenance", "host": ["{{baseUrl}}"], "path": ["api","maintenance"] }
          }
        },
        {
          "name": "Create Maintenance Record",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
